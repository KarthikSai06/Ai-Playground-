<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Design Grid connecting links -->
    <path
        android:strokeWidth="1.5"
        android:strokeColor="#40FFFFFF"
        android:strokeLineCap="round"
        android:pathData="M54,27 L54,81 M27,54 L81,54" />

    <!-- Orbital network boundary -->
    <path
        android:strokeWidth="1.0"
        android:strokeColor="#25FFFFFF"
        android:pathData="M54,54 m-27,0 a27,27 0 1,1 54,0 a27,27 0 1,1 -54,0" />

    <!-- Core Sparkle representing Intelligence Hub -->
    <path
        android:pathData="M54,34 Q54,54 74,54 Q54,54 54,74 Q54,54 34,54 Q54,54 54,34 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="34"
                android:startY="34"
                android:endX="74"
                android:endY="74"
                android:type="linear">
                <item android:offset="0.0" android:color="#FFFFFF" />
                <item android:offset="1.0" android:color="#D6F8FF" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- ChatGPT Integrated Node (Green) -->
    <path
        android:pathData="M54,27 m-5,0 a5,5 0 1,1 10,0 a5,5 0 1,1 -10,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="49"
                android:startY="22"
                android:endX="59"
                android:endY="32"
                android:type="linear">
                <item android:offset="0.0" android:color="#10A37F" />
                <item android:offset="1.0" android:color="#00695C" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Gemini Integrated Node (Blue) -->
    <path
        android:pathData="M81,54 m-5,0 a5,5 0 1,1 10,0 a5,5 0 1,1 -10,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="76"
                android:startY="49"
                android:endX="86"
                android:endY="59"
                android:type="linear">
                <item android:offset="0.0" android:color="#4285F4" />
                <item android:offset="1.0" android:color="#1A73E8" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Claude Integrated Node (Orange-Bronze) -->
    <path
        android:pathData="M54,81 m-5,0 a5,5 0 1,1 10,0 a5,5 0 1,1 -10,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="49"
                android:startY="76"
                android:endX="59"
                android:endY="86"
                android:type="linear">
                <item android:offset="0.0" android:color="#E67E22" />
                <item android:offset="1.0" android:color="#D35400" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Perplexity Integrated Node (Teal-Turquoise) -->
    <path
        android:pathData="M27,54 m-5,0 a5,5 0 1,1 10,0 a5,5 0 1,1 -10,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="22"
                android:startY="49"
                android:endX="32"
                android:endY="59"
                android:type="linear">
                <item android:offset="0.0" android:color="#1FC4D0" />
                <item android:offset="1.0" android:color="#11838F" />
            </gradient>
        </aapt:attr>
    </path>

</vector>
